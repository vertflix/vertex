{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "includes": [
      "**",
      "!**/public/**/*",
      "!**/dist/**/*",
      "!**/plugins/**/*.ts",
      "!**/plugins/**/*.mjs",
      "!**/themes/**/*.ts"
    ]
  },
  "linter": {
    "enabled": true,
    "includes": [
      "**",
      "!**/public/**/*",
      "!**/dist/**/*",
      "!**/plugins/**/*.ts",
      "!**/plugins/**/*.mjs",
      "!**/themes/**/*.ts"
    ],
    "rules": {
      "preset": "recommended",
      "a11y": "off",
      "style": {
        "noUselessElse": "off",
        "noParameterAssign": "off",
        "noNonNullAssertion": "off"
      },
      "complexity": {
        "noImportantStyles": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "useExhaustiveDependencies": "off"
      },
      "suspicious": {
        "noConsole": "off",
        "noShadowRestrictedNames": "off",
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noDocumentCookie": "off",
        "useIterableCallbackReturn": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnknownFunction": "off",
            "noUnknownPseudoClass": "off"
          },
          "style": {
            "noDescendingSpecificity": "off"
          },
          "suspicious": {
            "noDuplicateProperties": "off",
            "noUnknownAtRules": "off"
          }
        }
      }
    }
  ]
}
